# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=""

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=""                        # min 32 random chars
BETTER_AUTH_URL="http://localhost:3000"      # canonical app URL for redirects

# ─── OAuth providers ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App public URL (also used by Stream webhooks) ────────────────────────────
# NEXT_PUBLIC_* vars are inlined at `next build` time.
# When building the Docker image you must pass these as --build-arg.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stream Video (WebRTC + transcription + recording) ────────────────────────
NEXT_PUBLIC_STREAM_VIDEO_API_KEY=""          # exposed to browser
STREAM_VIDEO_SECRET_KEY=""                   # server-only

# ─── Stream Chat (real-time messaging) ───────────────────────────────────────
NEXT_PUBLIC_STREAM_CHAT_API_KEY=""           # exposed to browser
STREAM_CHAT_SECRET_KEY=""                    # server-only

# ─── OpenAI (GPT-4o summarization + real-time agent) ─────────────────────────
OPENAI_API_KEY=""

# ─── Polar.sh (billing / subscriptions) ──────────────────────────────────────
POLAR_ACCESS_TOKEN=""                        # use sandbox token in non-prod

# ─── Inngest ──────────────────────────────────────────────────────────────────
# Dev: leave blank — the local Inngest Dev Server container handles events.
# Prod: populate from https://app.inngest.com → your app → Manage → Keys
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# ─── Docker (optional overrides) ─────────────────────────────────────────────
PORT=3000

# Uncomment on Windows/macOS if Next.js hot reload stops detecting file changes
# WATCHPACK_POLLING=true

# Tag used by docker-compose.prod.yml when referencing a pre-built image
# IMAGE_TAG=abc1234
