# ─── Version control ─────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Dependencies (reinstalled inside the image) ─────────────────────────────
node_modules

# ─── Next.js build output (produced inside the image) ────────────────────────
.next
out

# ─── Environment files — never bake secrets into the image ───────────────────
.env
.env.*
!.env.example

# ─── Docker artifacts (no recursive Docker builds) ───────────────────────────
Dockerfile*
docker-compose*
.dockerignore

# ─── Local dev tooling ────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript incremental cache ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Test / coverage artifacts ───────────────────────────────────────────────
coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# ─── CI / deployment tooling ─────────────────────────────────────────────────
.vercel
.github

# ─── Editor artifacts ────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
